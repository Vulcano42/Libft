#include <stdio.h>

char *ft_strchr (const char *s, int c)

{
	char	*str;
	size_t	i;

	i = 0;
	while (*s)
	{
		if ((unsigned char *)s == (unsigned char*)c)
			return ((char*)s);
	}

	return(NULL);
}

int main (void)

{
	const char string[6] = "banana";

	printf ("s", ft_strchr(string,'a'));
	return(0);
}
